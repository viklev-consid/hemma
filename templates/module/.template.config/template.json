{
  "$schema": "http://json.schemastore.org/template",
  "author": "Hemma",
  "classifications": ["Hemma", "Module"],
  "identity": "Hemma.Module",
  "name": "Hemma Module",
  "shortName": "hemma-module",
  "description": "Scaffolds a complete Hemma module: internal project, contracts project, DbContext, module registration, and errors type.",
  "sourceName": "ModuleName",
  "symbols": {
    "moduleNameLower": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "lowerCaseInvariant",
      "replaces": "modulenamelower"
    }
  },
  "sources": [
    {
      "source": "./ModuleName",
      "target": ".",
      "include": ["**/*"],
      "exclude": [".template.config/**"]
    }
  ]
}
