{
  "$schema": "http://json.schemastore.org/template",
  "author": "Hemma",
  "classifications": ["Hemma", "Slice", "Feature", "Query"],
  "identity": "Hemma.QuerySlice",
  "name": "Hemma Query Slice",
  "shortName": "hemma-query-slice",
  "description": "Scaffolds a read/query vertical slice inside an existing module.",
  "sourceName": "FeatureName",
  "symbols": {
    "module": {
      "type": "parameter",
      "datatype": "string",
      "replaces": "ModuleName",
      "isRequired": true,
      "description": "The PascalCase module name this query slice belongs to (e.g. Catalog, Orders)."
    },
    "moduleNameLower": {
      "type": "derived",
      "valueSource": "module",
      "valueTransform": "lowerCaseInvariant",
      "replaces": "modulenamelower"
    },
    "featureNameLower": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "lowerCaseInvariant",
      "replaces": "featurenamelower"
    }
  },
  "sources": [
    {
      "source": "./Features/FeatureName",
      "target": ".",
      "include": ["**/*"],
      "exclude": [".template.config/**"]
    }
  ]
}
